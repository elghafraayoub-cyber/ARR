# ── Provider ────────────────────────────────────────────────────────────────
PROVIDER=vllm
MODEL=/models/Gem4

VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=vllm

OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama

# Must match your served model's actual context length. The client auto-caps
# output tokens so input + output never exceeds this.
CONTEXT_WINDOW=8192

# ── Agent loop budgets ─────────────────────────────────────────────────────
MAX_CRITIC_ROUNDS=3          # plan->work->critique->repair cycles per paper

# ── Dedup ───────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Paths ───────────────────────────────────────────────────────────────────
PAPERS_DIR=data/papers
OUTPUT_DIR=data/output
KG_PATH=data/output/soil_kg.json

# ── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
